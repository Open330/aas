{
  "$schema": "https://barshelf.dev/schema/widget-0.1.json",
  "schemaVersion": 1,
  "id": "dev.barshelf.aas-usage",
  "name": "aas Usage",
  "version": "0.3.0",
  "icon": "gauge",
  "bucket": {
    "group": "Agents",
    "order": 21,
    "size": "M"
  },
  "entry": {
    "kind": "exec"
  },
  "source": {
    "kind": "exec",
    "command": [
      "aas",
      "usage",
      "--json"
    ],
    "discover": [
      "$AAS_BIN",
      "~/.local/bin/aas",
      "~/bin/aas",
      "~/.cargo/bin/aas",
      "/opt/homebrew/bin/aas",
      "/usr/local/bin/aas",
      "PATH"
    ],
    "timeoutMs": 25000,
    "output": "data",
    "adapter": "aas-usage"
  },
  "refresh": {
    "onOpen": true,
    "interval": null,
    "staleAfterSec": 600,
    "watchPaths": [],
    "runInBackground": false,
    "popupOnly": true,
    "triggers": []
  },
  "permissions": {
    "exec": [
      {
        "command": "aas",
        "allowedArgs": [
          [
            "usage",
            "--json"
          ]
        ],
        "maxOutputBytes": 1048576,
        "sensitiveOutput": false
      }
    ],
    "network": [],
    "readPaths": [],
    "env": [
      "AAS_BIN"
    ],
    "keychain": false
  },
  "settings": [],
  "appearance": {
    "accent": "orange"
  }
}
