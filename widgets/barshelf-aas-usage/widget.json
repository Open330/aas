{
  "$schema": "https://barshelf.dev/schema/widget-0.1.json",
  "schemaVersion": 1,
  "id": "dev.barshelf.aas-usage",
  "name": "aas Usage",
  "version": "0.4.0",
  "icon": "gauge",
  "bucket": {
    "group": "Agents",
    "order": 21,
    "size": "M"
  },
  "entry": {
    "kind": "workflow",
    "main": "workflow.json"
  },
  "refresh": {
    "onOpen": true,
    "interval": null,
    "staleAfterSec": 600,
    "watchPaths": [],
    "runInBackground": false,
    "popupOnly": true,
    "triggers": []
  },
  "permissions": {
    "exec": [
      {
        "command": "aas",
        "allowedArgs": [
          [
            "usage",
            "--json"
          ]
        ],
        "maxOutputBytes": 1048576,
        "sensitiveOutput": false
      }
    ],
    "network": [],
    "readPaths": [],
    "env": [
      "AAS_BIN"
    ],
    "keychain": false
  },
  "settings": [],
  "appearance": {
    "accent": "orange"
  }
}
